{
  "info": {
    "name": "Spykar Inventory Intelligence API",
    "description": "Complete API collection for the Spykar Jeans Inventory Intelligence Platform.\n\n**Setup:**\n1. Set the `baseUrl` variable to your server URL (default: http://localhost:4000/api/v1)\n2. Run the `Login` request first — it auto-sets `accessToken` and `refreshToken`\n3. All other requests use the `accessToken` automatically\n\n**Test Credentials (after seeding):**\n- admin@spykar.com / Admin@123\n- manager@spykar.com / Manager@123\n- viewer@spykar.com / Viewer@123",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "spykar-v1"
  },
  "variable": [
    { "key": "baseUrl",      "value": "http://localhost:4000/api/v1", "type": "string" },
    { "key": "accessToken",  "value": "", "type": "string" },
    { "key": "refreshToken", "value": "", "type": "string" },
    { "key": "locationId",   "value": "", "type": "string" },
    { "key": "skuId",        "value": "", "type": "string" },
    { "key": "dispatchId",   "value": "", "type": "string" }
  ],
  "item": [

    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Login",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const res = pm.response.json();",
                "if (res.success) {",
                "  pm.collectionVariables.set('accessToken',  res.data.accessToken);",
                "  pm.collectionVariables.set('refreshToken', res.data.refreshToken);",
                "  pm.test('Login successful', () => pm.expect(res.success).to.be.true);",
                "  pm.test('Access token returned', () => pm.expect(res.data.accessToken).to.be.a('string'));",
                "  console.log('✅ Logged in as:', res.data.user.email);",
                "}"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@spykar.com\",\n  \"password\": \"Admin@123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Get Current User (Me)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/auth/me", "host": ["{{baseUrl}}"], "path": ["auth", "me"] }
          }
        },
        {
          "name": "Refresh Token",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const res = pm.response.json();",
                "if (res.success) {",
                "  pm.collectionVariables.set('accessToken',  res.data.accessToken);",
                "  pm.collectionVariables.set('refreshToken', res.data.refreshToken);",
                "}"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" },
            "url": { "raw": "{{baseUrl}}/auth/refresh", "host": ["{{baseUrl}}"], "path": ["auth", "refresh"] }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/auth/logout", "host": ["{{baseUrl}}"], "path": ["auth", "logout"] }
          }
        },
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/../health", "raw": "http://localhost:4000/health" }
          }
        },
        {
          "name": "Deep Health Check",
          "request": {
            "method": "GET",
            "url": { "raw": "http://localhost:4000/health/deep" }
          }
        }
      ]
    },

    {
      "name": "📊 Inventory",
      "item": [
        {
          "name": "Executive Summary",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/inventory/executive-summary", "host": ["{{baseUrl}}"], "path": ["inventory", "executive-summary"] }
          }
        },
        {
          "name": "Snapshot — All Stock",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/inventory/snapshot?page=1&limit=50",
              "host": ["{{baseUrl}}"], "path": ["inventory", "snapshot"],
              "query": [
                { "key": "page",  "value": "1" },
                { "key": "limit", "value": "50" }
              ]
            }
          }
        },
        {
          "name": "Snapshot — Filter by Size 34",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/inventory/snapshot?size=34&sort_by=qty_on_hand&sort_order=DESC",
              "host": ["{{baseUrl}}"], "path": ["inventory", "snapshot"],
              "query": [
                { "key": "size",       "value": "34" },
                { "key": "sort_by",    "value": "qty_on_hand" },
                { "key": "sort_order", "value": "DESC" }
              ]
            }
          }
        },
        {
          "name": "Snapshot — Distributors Only, Below Safety",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/inventory/snapshot?location_type=DISTRIBUTOR&below_safety=true",
              "host": ["{{baseUrl}}"], "path": ["inventory", "snapshot"],
              "query": [
                { "key": "location_type", "value": "DISTRIBUTOR" },
                { "key": "below_safety",  "value": "true" }
              ]
            }
          }
        },
        {
          "name": "Stock Alerts",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/inventory/alerts", "host": ["{{baseUrl}}"], "path": ["inventory", "alerts"] }
          }
        },
        {
          "name": "Stock Ageing",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/inventory/ageing", "host": ["{{baseUrl}}"], "path": ["inventory", "ageing"] }
          }
        },
        {
          "name": "Movement Ledger",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/inventory/movements?limit=50&page=1",
              "host": ["{{baseUrl}}"], "path": ["inventory", "movements"],
              "query": [{ "key": "limit", "value": "50" }, { "key": "page", "value": "1" }]
            }
          }
        },
        {
          "name": "Movements — Sales Only",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/inventory/movements?movement_type=SALE&limit=50",
              "host": ["{{baseUrl}}"], "path": ["inventory", "movements"],
              "query": [{ "key": "movement_type", "value": "SALE" }, { "key": "limit", "value": "50" }]
            }
          }
        },
        {
          "name": "Export Snapshot as CSV",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/inventory/snapshot/export", "host": ["{{baseUrl}}"], "path": ["inventory", "snapshot", "export"] }
          }
        },
        {
          "name": "Manual Stock Adjustment (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"location_id\": \"{{locationId}}\",\n  \"sku_id\": \"{{skuId}}\",\n  \"qty_change\": 50,\n  \"reason\": \"Manual correction after physical count\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/inventory/adjust", "host": ["{{baseUrl}}"], "path": ["inventory", "adjust"] }
          }
        }
      ]
    },

