{
  "name": "spykar-inventory-api",
  "version": "1.0.0",
  "description": "Spykar Jeans — AI-Powered Inventory Intelligence API",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "dev:debug": "nodemon --inspect src/server.js",
    "lint": "eslint src/ --ext .js",
    "db:migrate": "node src/database/migrate.js",
    "db:seed": "node src/database/seed.js",
    "sync:manual": "node -e \"require('./src/services/syncEngine').runDeltaSync('MANUAL').then(console.log)\"",
    "sync:full": "node src/scripts/run_full_sync.js",
    "ageing:update": "node src/scripts/run_ageing_update.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "bcrypt": "^5.1.1",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "express-validator": "^7.1.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mssql": "^11.0.1",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.3",
    "pg": "^8.13.0",
    "redis": "^4.7.0",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "eslint": "^9.8.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}